---
import TopBlueHeader from "../../components/TopBlueHeader.astro";
import SiteFooter from "../../components/Footer.astro";
const {
  backHref = "/events",
  backLabel = "Back to All Events",
  title = "UN CAREER OPPORTUNITIES",
  date = "Monday, April 7, 2025",
  time = "5:00 PM – 7:00 PM",
  body = [
    "On April 7th, LUSDA had the great pleasure of hosting Dr. Gherardo Casini, Director of the UN Department of Economic and Social Affairs – Rome Office, for an exclusive career development talk in Aula Toti.",
    "During the event, Dr. Casini guided students through the multiple career-entry paths into the UN system, focusing on concrete programmes like the Young Professionals Programme (YPP), UN Internships, and UN Volunteer opportunities. A special spotlight was given to the Italian JPO Programme and the Italian Fellowship Programme, two valuable opportunities supported by the Italian government and coordinated by UN/DESA.",
    "Beyond explaining how to apply and what qualifications are most in demand, Dr. Casini offered insightful advice on how to succeed in interviews, build an international profile, and navigate a career in global public service, drawing from his own rich and multifaceted experience within the UN system."
  ]
} = Astro.props;
export const prerender = true;
---


<TopBlueHeader
  logoSrc="/Pictures/Logo.png"
  sticky={false}
/>
    <body class="page">
    <main class="wrap" aria-labelledby="event-title">
      <a class="back" href={backHref}>← {backLabel}</a>

      <h1 id="event-title" class="title">{title}</h1>

      <div class="meta">
        <p class="date">{date}</p>
        <p class="time">{time}</p>
      </div>

      <section class="body">
        {body.map((p) => <p class="para">{p}</p>)}
      </section>
    </main>
  </body>
</html>

<style>
  :root {
    --bg: #0f2a40;
    --fg: #1F3454;
    --fg-dim: #1F3454;
    --fg-strong: #1F3454;
    --accent: #1F3454;
    --maxw: 1200px;
    --pad-x: clamp(16px, 4vw, 48px);
    --pad-y: clamp(20px, 4vw, 40px);
  }

  .page {
    margin: 0;
    min-height: 100vh;
    background: #1F3454;
    color: #1F3454;
    font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, "Helvetica Neue",
      Arial, "Noto Sans", "Liberation Sans", sans-serif;
  }

  .wrap {
    max-width: var(--maxw);
    margin-inline: auto;
    padding: var(--pad-y) var(--pad-x);
  }

  .back {
    display: inline-block;
    margin-bottom: 2rem;
    color: var(--fg-dim);
    text-decoration: none;
    font-weight: 600;
  }
  .back:hover {
    color: var(--accent);
    text-decoration: underline;
  }

  .title {
    margin: 0 0 1rem;
    color: var(--fg-strong);
    font-size: clamp(28px, 3.6vw, 44px);
    font-weight: 800;
    line-height: 1.15;
  }

  .meta {
    margin-bottom: 2rem;
  }
  .date,
  .time {
    margin: 0;
    color: var(--fg-dim);
    font-size: clamp(14px, 1.6vw, 18px);
    font-weight: 600;
  }

  .body {
 
  }

  .para {
    margin: 0 0 1.5rem;
    line-height: 1.8;
    font-size: clamp(16px, 1.7vw, 18px);
    color: var(--fg);
  }
</style>
<SiteFooter
  joinHref="/member"
  location="Rome, RM, Italy"
  email="lusdaassociation@gmail.com"
  linkedin="https://www.linkedin.com/your-page"
  instagram="https://instagram.com/your-page"
/>
</html>
---
import TopBlueHeader from "../../components/TopBlueHeader.astro";
import SiteFooter from "../../components/Footer.astro";
const {
  backHref = "/events",
  backLabel = "Back to All Events",
  title = "LUSDA Brussels Study Trip - Day 1",
  date = "Monday, January 27, 2025",
  time = "1:30 PM – 2:30 PM",
  body = [
    "During our first day of study trip to Brussels, we were excited to be able to spend an amazing afternoon at the NATO headquarters right outside the center.",
    "Throughout 3 different talks, our delegation of 16 students could learn more about NATO’s Agenda and the organization’s digital outreach through social media. As the highlight of the day, after a pleasant coffee break and a small tour of the HQ, Mario Ventrone, Second Secretary at the Permanent Representation of Italy to the Atlantic Council, was so kind to offer some of his precious time to discuss with the students the Italy-NATO relations. ",
    "In this occasion, we want to thank the Italian Permanent Representation at NATO as well as the Public Diplomacy Division of the headquarters for making this visit possible. Heartfelt thanks go also out to Giulio, our Study Visits Officer, for coordinating the visit with NATO. ",
    "For LUSDA, this has been an amazing opportunity and also a great start into our week in Brussels. Stay tuned for more!"
  ]
} = Astro.props;
export const prerender = true;
---


<TopBlueHeader
  logoSrc="/Pictures/Logo.png"
  sticky={false}
/>
    <body class="page">
    <main class="wrap" aria-labelledby="event-title">
      <a class="back" href={backHref}>← {backLabel}</a>

      <h1 id="event-title" class="title">{title}</h1>

      <div class="meta">
        <p class="date">{date}</p>
        <p class="time">{time}</p>
      </div>

      <section class="body">
        {body.map((p) => <p class="para">{p}</p>)}
      </section>
    </main>
  </body>
</html>

<style>
  :root {
    --bg: #0f2a40;
    --fg: #1F3454;
    --fg-dim: #1F3454;
    --fg-strong: #1F3454;
    --accent: #1F3454;
    --maxw: 1200px;
    --pad-x: clamp(16px, 4vw, 48px);
    --pad-y: clamp(20px, 4vw, 40px);
  }

  .page {
    margin: 0;
    min-height: 100vh;
    background: #1F3454;
    color: #1F3454;
    font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, "Helvetica Neue",
      Arial, "Noto Sans", "Liberation Sans", sans-serif;
  }

  .wrap {
    max-width: var(--maxw);
    margin-inline: auto;
    padding: var(--pad-y) var(--pad-x);
  }

  .back {
    display: inline-block;
    margin-bottom: 2rem;
    color: var(--fg-dim);
    text-decoration: none;
    font-weight: 600;
  }
  .back:hover {
    color: var(--accent);
    text-decoration: underline;
  }

  .title {
    margin: 0 0 1rem;
    color: var(--fg-strong);
    font-size: clamp(28px, 3.6vw, 44px);
    font-weight: 800;
    line-height: 1.15;
  }

  .meta {
    margin-bottom: 2rem;
  }
  .date,
  .time {
    margin: 0;
    color: var(--fg-dim);
    font-size: clamp(14px, 1.6vw, 18px);
    font-weight: 600;
  }

  .body {

  }

  .para {
    margin: 0 0 1.5rem;
    line-height: 1.8;
    font-size: clamp(16px, 1.7vw, 18px);
    color: var(--fg);
  }
</style>
<SiteFooter
  joinHref="/member"
  location="Rome, RM, Italy"
  email="lusdaassociation@gmail.com"
  linkedin="https://www.linkedin.com/your-page"
  instagram="https://instagram.com/your-page"
/>
</html>
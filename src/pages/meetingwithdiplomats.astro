---
import TopBlueHeader from "../components/TopBlueHeader.astro";
import SiteFooter from "../components/Footer.astro";
import KeenCarousel from "../components/KeenCarousel.astro";
export const prerender = true;
const items = [
  { img: "/Pictures/Invaluable.jpeg", title: "INVALUABLE ACCESS", body: "…" },
  { img: "/Pictures/InYourWords.png", title: "IN YOUR WORDS", body: "…" },
  { img: "/Pictures/meetings/3.jpg", title: "DIPLOMATIC CAREERS", body: "…" },
  { img: "/Pictures/meetings/4.jpg", title: "CURRENT AFFAIRS", body: "…" },
  { img: "/Pictures/meetings/5.jpg", title: "CULTURAL EXCHANGE", body: "…" },
];
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Meetings with Diplomats</title>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700&family=Libre+Baskerville:wght@400;700;800&display=swap" rel="stylesheet">
  <link rel="icon" type="image/png" href="/Pictures/favicon.png">
</head>
<body>
  <TopBlueHeader
    logoSrc="/Pictures/Logo.png"
    sticky={false}
  />
  <main>
    <section
      class="meeting-hero"
      style={`--bg:url('/Pictures/MeetingDiplomatsBackground.JPG')`}
    >
      <div class="meeting-hero__img" role="img" aria-label="Meetings with diplomats"></div>
      <div class="meeting-hero__scrim"></div>
      <div class="meeting-hero__content">
        <h1>
          <span>MEETINGS WITH</span>
          <span>DIPLOMATS</span>
        </h1>
      </div>
    </section>
    <section class="summary-angled">
      <div class="summary-wrap">
        <div class="summary-left">
          <p>ROUGHLY IN A FEW<br/>WORDS&#8230;</p>
        </div>
        <div class="summary-right">
          <p class="summary-text">
            THE MEETINGS WITH DIPLOMATS EVENTS
            OFFER AN <span class="ring">EXCEPTIONAL</span> OPPORTUNITY
            FOR LUSDA MEMBERS TO ENGAGE
            DIRECTLY WITH <mark class="hl">KEY FIGURES</mark> IN
            DIPLOMACY SUCH AS AMBASSADORS AND
            DIPLOMATIC OFFICIALS. THESE MEETINGS
            ALLOW FOR FIRSTHAND <span class="uline">CONVERSATIONS</span>
            WITH PERSONALITIES WHO NAVIGATE
            GLOBAL AFFAIRS DAILY.
          </p>
        </div>
      </div>
    </section>
    <section class="expect-title">
      <div class="expect-wrap">
        <h2 class="expect-heading">
          WHAT TO EXPECT FROM OUR DIPLOMATIC MEETINGS
        </h2>
      </div>
    </section>
    <div class="expect-cards">
      <KeenCarousel gap={20}>
        <article class="card">
          <div class="media"><img src="/Pictures/Invaluable.jpeg" alt="" /></div>
          <h3>INVALUABLE ACCESS</h3>
          <p>Stay informed about the latest developments in global politics and diplomacy. Diplomats often share their views on current events, emerging trends, and the impact of recent international decisions.</p>
        </article>
        <article class="card">
          <div class="media"><img src="/Pictures/InYourWords.png" alt="" /></div>
          <h3>IN YOUR WORDS</h3>
          <p>Engage in face-to-face discussions with current and former diplomats, ambassadors and high-ranking officials. These meetings are designed to provide you with unique perspectives on international relations, policy-making, and diplomatic negotiations.</p>
        </article>
        <article class="card">
          <div class="media"><img src="/Pictures/DiplomaticCareers.png" alt="" /></div>
          <h3>DIPLOMATIC CAREERS</h3>
          <p>Learn about the diverse career paths within diplomacy and international relations. Our meetings often include personal career stories, advice on pursuing a career in diplomacy, and discussions on the skills and experiences necessary for success in the field.</p>
        </article>
        <article class="card">
          <div class="media"><img src="/Pictures/CurrentAffairs.png" alt="" /></div>
          <h3>CURRENT AFFAIRS</h3>
          <p>Stay informed about the latest developments in global politics and diplomacy. Diplomats often share their views on current events, emerging trends, and the impact of recent international decisions.</p>
        </article>
        <article class="card">
          <div class="media"><img src="/Pictures/Networking.png" alt="" /></div>
          <h3>Networking</h3>
          <p>Build connections with professionals in the diplomatic field. These meetings provide a platform for networking with diplomats and other attendees, which can lead to mentorship, internships, and future career opportunities.</p>
        </article>
      </KeenCarousel>
    </div>
  </main>
  <SiteFooter
    joinHref="/member"
    location="Rome, RM, Italy"
    email="lusdaassociation@gmail.com"
  />
</body>
</html>
<style>

  .meeting-hero{position: relative;min-height: clamp(420px, 62vh, 760px);overflow: hidden;background:#0b1d31;}
  .meeting-hero__img{position:absolute; inset:0;background-image: var(--bg);background-size: cover;background-position: center;transform: translateZ(0);}
  .meeting-hero__scrim{position:absolute; inset:0;background: linear-gradient(90deg, rgba(0,0,0,.38) 0%, rgba(0,0,0,.18) 45%, rgba(0,0,0,.05) 75%, rgba(0,0,0,0) 100%);pointer-events:none;}
  .meeting-hero__content{position:absolute;left: clamp(16px, 5vw, 56px);bottom: clamp(20px, 8vh, 80px);color:#fff;}
  .meeting-hero h1{margin:0;line-height: .95;text-transform: uppercase;letter-spacing: .02em;font-weight: 800;font-family: "Libre Baskerville", serif;text-shadow: 0 2px 12px rgba(0,0,0,.35);font-size: clamp(1.6rem, 6vw, 4rem);}
  .meeting-hero h1 span{ display:block; }
  .summary-angled{position: relative;background:#F4F0EC;color:#0f3554;padding: clamp(3rem,6vw,6rem) 1rem clamp(4rem,7vw,7rem);overflow: hidden;}
  .summary-angled::after{content:"";position:absolute; left:0; right:0; bottom:-8vw;height:16vw;background:#fff;transform:skewY(6deg);transform-origin:left bottom;pointer-events:none;}
  .summary-wrap{max-width:1200px;margin:0 auto;display:grid;grid-template-columns: 1fr 3fr;gap: clamp(1.5rem,4vw,3.5rem);}
  @media (max-width: 820px){.summary-wrap{ grid-template-columns: 1fr; }}
  .summary-left p{margin:0;font-family:"Libre Baskerville",serif;text-transform:uppercase;letter-spacing:.06em;font-size: clamp(.85rem,1.4vw,1rem);opacity:.9;}
  .summary-right{ align-self:start; }
  .summary-text{margin:0;font-family:"Libre Baskerville",serif;font-weight:550;letter-spacing:.02em;line-height:1.25;font-size: clamp(1.2rem,2.9vw,2.25rem);}
  .ring{position:relative;display:inline-block;padding: .12em .52em .16em;}
  .ring::before{content:"";position:absolute; inset:-.38em -.72em;border:4px solid #0f3554;border-radius:9999px;opacity:.9;pointer-events:none;}
  .hl{background:#fff45a;color:inherit;padding: .05em .2em;}
  .uline{background:linear-gradient(currentColor,currentColor) 0 100%/100% 2px no-repeat;padding-bottom:.08em;}
  .expect-title{background:#fff;padding: clamp(1.25rem, 5vw, 3rem) 1rem;}
  .expect-wrap{max-width: 1200px;margin: 0 auto;}
  .expect-heading{margin: 0;text-align: center;font-family: "Libre Baskerville", serif;text-transform: uppercase;letter-spacing: .02em;font-weight: 700;line-height: 1;color: #0f3554;font-size: clamp(1.2rem, 3.8vw, 2.6rem);}
  .expect-cards .card{text-align: left;}
  .expect-cards .card .media{ margin-bottom: .6rem; }
  .expect-cards .card .media img{display:block;width:100%; height:auto; border-radius: 8px;}
  .expect-cards .card h3{margin: .2rem 0 .25rem;font-family: "Libre Baskerville", serif;text-transform: uppercase;letter-spacing: .02em;font-weight: 700;line-height: 1;color: #000000;font-size: clamp(1.1rem, 2.3vw, 1.75rem);text-align: left;}
  .expect-cards .card p{margin: 0;font-family: "Montserrat", system-ui, sans-serif;color: #000000;opacity: .88;font-size: clamp(.95rem, 1.2vw, 1.05rem);line-height: 1.6;}
</style>
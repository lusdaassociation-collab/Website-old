---
import TopBlueHeader from "../components/TopBlueHeader.astro";
import SiteFooter from "../components/Footer.astro";
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>LUSDA - Contact Us</title>
  <link rel="icon" type="image/png" href="/Pictures/favicon.png">
</head>
<body>
  <TopBlueHeader
    logoSrc="/Pictures/Logo.png"
    sticky={false}
  />
  <main>
    <section class="contact">
      <div class="wrap">
        <div class="left">
          <h1>REACH OUT TO LUSDA</h1>
          <p class="lede">
            At LUSDA, we believe in the power of collaboration to drive meaningful change in the world of
            international relations and diplomacy. We are always on the lookout for passionate individuals,
            organizations, and institutions that share our commitment to fostering a deeper understanding of global issues.
          </p>
          <p class="lede">
            Join us in shaping the future of international relations—together, we can make a difference.
          </p>
          <form action="https://api.web3forms.com/submit" method="POST">
            <input type="hidden" name="access_key" value="971ba36a-e275-43e1-95e5-6d1025012159">
            <input type="hidden" name="redirect" value="https://lusda.org/thankyou/">
            <div class="field">
              <label>Name <span class="req">(required)</span></label>
              <div class="two">
                <input name="firstName" placeholder="First Name" required />
                <input name="lastName" placeholder="Last Name" required />
              </div>
            </div>
            <div class="field">
              <label>Email <span class="req">(required)</span></label>
              <input type="email" name="email" placeholder="you@example.com" required />
            </div>
            <div class="field">
              <label>Message <span class="req">(required)</span></label>
              <textarea name="message" rows="6" placeholder="How can we help?" required></textarea>
            </div>
            <div class="actions">
              <button id="sendBtn" type="submit">SEND</button>
              <span id="form-status" role="status" aria-live="polite"></span>
            </div>
          </form>
        </div>
        <div class="right">
          <img src="/Pictures/contact.jpg" alt="LUSDA event audience with Q&A" />
        </div>
      </div>
    </section>
  </main>
  <SiteFooter
    joinHref="/member"
    location="Rome, RM, Italy"
    email="lusdaassociation@gmail.com"
  />
</body>
</html>
<style>
  :root{--page-bg:#f3efe9;--ink:#1d2433;--blue:#22324a;--muted:#667084;--input:#e7e3dc;}
  .contact{ background:var(--page-bg); }
  .contact .wrap{max-width: 1200px;margin: 0 auto;padding: clamp(24px,3vw,32px) clamp(16px,2.4vw,28px) clamp(40px,6vw,56px);display: grid;grid-template-columns: 1.05fr 1fr;gap: clamp(24px,4vw,52px);align-items: start;}
  .left h1{margin: 0 0 18px;color: var(--blue);font-size: clamp(1.8rem, 5vw, 3.25rem);line-height: 1;text-transform: uppercase;font-weight: 900;letter-spacing: .02em;}
  .lede{color: var(--ink);opacity: .95;line-height: 1.7;margin: 0 0 12px;}
  form{ margin-top: 18px; }
  .field{ margin-bottom: 16px; }
  label{display:block;font-weight: 700;margin-bottom: 6px;color: var(--ink);}
  .req{ color: var(--muted); font-weight: 600; margin-left: 6px; }
  .two{display:grid;grid-template-columns: 1fr 1fr;gap: 12px;}
  input, textarea{width: 100%;font: inherit;color: var(--ink);background: #fff;border: 1px solid #d8d7d2;border-radius: 8px;padding: 12px 14px;outline: none;transition: box-shadow .15s ease, border-color .15s ease;}
  input:focus, textarea:focus{border-color: var(--blue);box-shadow: 0 0 0 3px rgba(34,50,74,.15);}
  .actions{display:flex;align-items:center;gap: 12px;margin-top: 8px;}
  #sendBtn{background: var(--blue);color: #fff;border: 0;border-radius: 10px;padding: 12px 26px;font-weight: 800;letter-spacing: .02em;cursor: pointer;box-shadow: 0 2px 10px rgba(0,0,0,.08);transition: transform .1s ease, box-shadow .1s ease, opacity .2s ease;}
  #sendBtn:hover{ transform: translateY(-1px); box-shadow: 0 6px 18px rgba(0,0,0,.12); }
  #sendBtn:disabled{ opacity:.6; cursor:not-allowed; }
  #form-status{ color: var(--blue); font-weight: 600; }
  .right img{width: 100%;height: auto;display: block;border-radius: 6px;box-shadow: 0 10px 30px rgba(0,0,0,.08);}
  @media (max-width: 980px){.contact .wrap{ grid-template-columns: 1fr; }.right{ order: -1; }}
</style>
---
import TopBlueHeader from "../components/TopBlueHeader.astro";
import SiteFooter from "../components/Footer.astro";
import EventCard from "../components/EventCard.astro";

/** * Replace these values with your actual Google Sheet ID and Tab Name 
 * Ensure your Google Sheet is "Published to the Web"
 */
const SHEET_ID = '1N3mrF58xqUCMS6gKapDJUVkVI5p2iE6nzCGybS3jrUk';
const TAB_NAME = 'Events'; 

const response = await fetch(`https://opensheet.elk.sh/${SHEET_ID}/${TAB_NAME}`);
const EVENTS = await response.json(); 
---

<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LUSDA - Events</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700&family=Georgia&display=swap" rel="stylesheet">
</head>
<body>
<TopBlueHeader
  logoSrc="/Pictures/Logo.png"
  sticky={false}
/>
    <section class="events-banner">
      <img class="events-banner__bg" src="/Pictures/events.png" alt="Students around interactive table">
      <div class="events-banner__overlay" aria-hidden="true"></div>
      <h2 class="events-banner__title">UPCOMING & PAST EVENTS</h2>
    </section>

    <section class="events-feed">
      <div class="events-feed__wrap">
        <div class="events-list">
          {EVENTS.map(event => <EventCard event={event} />)}
        </div>
      </div>
    </section>

    <SiteFooter
      joinHref="/member"
      location="Rome, RM, Italy"
      email="lusdaassociation@gmail.com"
      linkedin="https://www.linkedin.com/your-page"
      instagram="https://instagram.com/your-page"
    />
</body>
</html>

<style is:global>
  body {
    margin: 0;
    font-family: 'Montserrat', sans-serif;
  }
  .events-banner {
    position: relative;
    width: 100%;
    height: clamp(260px, 42vh, 520px);
    overflow: hidden;
    border-top: 4px solid #2a3f6a;
  }
  .events-banner__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 45%;
  }
  .events-banner__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(0,0,0,.25), rgba(0,0,0,.25));
  }
  .events-banner__title {
    position: absolute;
    inset: 0;
    margin: 0;
    display: grid;
    place-items: center;
    color: #fff;
    text-align: center;
    text-transform: uppercase;
    font-family: 'Georgia', serif;
    font-weight: 700;
    letter-spacing: .06em;
    font-size: clamp(1.5rem, 4.4vw, 3rem);
    text-shadow: 0 2px 10px rgba(0,0,0,.35);
    padding: 0 1rem;
  }
  .events-feed {
    background: #1e2a4a;
    color: #ffffff;
    padding: 4rem 1.5rem;
  }
  .events-feed__wrap {
    max-width: 1100px;
    margin: 0 auto;
  }
  .events-list {
    display: grid;
    gap: 3.5rem;
  }
</style>
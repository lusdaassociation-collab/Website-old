---

const {
  title = "PAST & UPCOMING EVENTS",
  blurb = "Stay engaged and informed with LUSDA’s diverse range of events designed to enhance your understanding of international relations and diplomacy.",
  startYear = new Date().getFullYear(),
  startMonth = new Date().getMonth(),
  events = [],
} = Astro.props;

const id = `cal-${Math.random().toString(36).slice(2, 8)}`;
---
<section class="bg-[#F4F0EC] text-[#0f3554]">
  <div class="mx-auto max-w-[1200px] px-4 py-16">
    <h2
      class="uppercase tracking-[0.08em] text-left
             text-[clamp(1.6rem,3vw,2.2rem)] font-semibold"
      style="font-family:'Montserrat',system-ui,sans-serif;"
    >
      {title}
    </h2>
    <p
      class="mt-3 text-[14px] md:text-[15px] leading-6 max-w-[72ch] text-[#0f3554]/80"
      style="font-family:'Inter',system-ui,sans-serif;"
    >
      {blurb}
    </p>

    <div class="mt-6 flex items-center justify-between max-w-[700px]">
      <button data-prev
              class="h-8 w-8 inline-grid place-items-center rounded-full border border-[#0f3554]/30 text-[#0f3554]/80 hover:bg-[#0f3554]/5"
              aria-label="Previous month">‹</button>
      <div class="text-center flex-1">
        <div id={`${id}-label`}
             class="uppercase tracking-[.05em] font-semibold"
             style="font-family:'Montserrat',system-ui,sans-serif;">

        </div>
      </div>
      <button data-next
              class="h-8 w-8 inline-grid place-items-center rounded-full border border-[#0f3554]/30 text-[#0f3554]/80 hover:bg-[#0f3554]/5"
              aria-label="Next month">›</button>
    </div>


    <div class="mt-4 grid grid-cols-7 text-[10px] md:text-[11px] uppercase tracking-wider text-[#0f3554]/70 select-none"
         style="font-family:'Inter',system-ui,sans-serif;">
      <div class="py-2 text-center">Su</div>
      <div class="py-2 text-center">Mo</div>
      <div class="py-2 text-center">Tu</div>
      <div class="py-2 text-center">We</div>
      <div class="py-2 text-center">Th</div>
      <div class="py-2 text-center">Fr</div>
      <div class="py-2 text-center">Sa</div>
    </div>


    <div id={id}
         class="grid grid-cols-7 border border-[#0f3554]/10 bg-white/40"
         style="--cell-h: 92px;">

    </div>
  </div>
</section>

<style is:global>
  .cal-cell {
    height: var(--cell-h);
    border-right: 1px solid rgba(15,53,84,.08);
    border-bottom: 1px solid rgba(15,53,84,.08);
    background: rgba(246,243,239,.5);
    position: relative;
  }
  .cal-cell:nth-child(7n) { border-right: none; }
  .cal-day {
    position: absolute; top: 8px; right: 10px;
    font-size: 12px; color: rgba(15,53,84,.6);
    font-family: 'Inter', system-ui, sans-serif;
  }
  .cal-dot {
    position: absolute; top: 10px; left: 10px;
    width: 6px; height: 6px; border-radius: 9999px;
    background: #0f3554;
    opacity: .9;
  }
  .cal-cell.has-event:hover { background: rgba(15,53,84,.06); }
  .cal-today {
    outline: 2px solid rgba(15,53,84,.25);
    outline-offset: -2px;
    background: rgba(255,255,255,.6);
  }
</style>

<script is:inline>
  (function(){
    const grid = document.getElementById({id:JSON.stringify(id)});
    const label = document.getElementById({id:JSON.stringify(id)} + "-label");

    const START_YEAR  = Number({startYear});
    const START_MONTH = Number({startMonth});
    const EVENTS = {json:JSON.stringify(events)};

    let year  = START_YEAR;
    let month = START_MONTH;

    const MONTHS = ["January","February","March","April","May","June","July","August","September","October","November","December"];

    function fmt(y,m,d){
      const mm = String(m+1).padStart(2,'0');
      const dd = String(d).padStart(2,'0');
      return `${y}-${mm}-${dd}`;
    }

    function render(){

      label.textContent = `${MONTHS[month]} ${year}`;


      const map = new Map();
      EVENTS.forEach(e => {
        (map.get(e.date) || map.set(e.date, []).get(e.date)).push(e);
      });


      grid.innerHTML = "";
      const firstDow = new Date(year, month, 1).getDay();
      const daysIn   = new Date(year, month+1, 0).getDate();
      const today    = new Date();
      const isThisMonth = today.getFullYear()===year && today.getMonth()===month;


      for (let i=0; i<42; i++){
        const dayNum = i - firstDow + 1;
        const cell = document.createElement('div');
        cell.className = "cal-cell";

        if (dayNum > 0 && dayNum <= daysIn){

          const num = document.createElement('div');
          num.className = "cal-day";
          num.textContent = dayNum;
          cell.appendChild(num);


          const key = fmt(year, month, dayNum);
          const events = map.get(key);
          if (events && events.length){
            cell.classList.add('has-event');
            const dot = document.createElement('div');
            dot.className = "cal-dot";
            cell.appendChild(dot);

            cell.title = events.map(e => e.title).join("\\n");

            if (events.length === 1 && events[0].url){
              cell.style.cursor = "pointer";
              cell.addEventListener('click', () => { window.location.href = events[0].url; });
            }
          }


          if (isThisMonth && dayNum === today.getDate()){
            cell.classList.add('cal-today');
          }
        } else {
          cell.style.background = "transparent";
        }

        grid.appendChild(cell);
      }
    }

    // nav
    const root = grid.closest('[class*="max-w"]');
    root.querySelector('[data-prev]').addEventListener('click', () => {
      month--; if (month < 0){ month = 11; year--; } render();
    });
    root.querySelector('[data-next]').addEventListener('click', () => {
      month++; if (month > 11){ month = 0; year++; } render();
    });

    render();
  })();
</script>
---
const { event } = Astro.props;
---

<article class="event-row">
  <div class="event-media">
    <a href={event.link}>
      <img src={event.img} alt={event.title} loading="lazy" />
    </a>
  </div>
  <div class="event-meta">
    <h3 class="event-title">{event.title}</h3>
    <p class="event-date" set:html={event.date}></p>
    <div class="event-cta">
      <a href={event.link} class="btn-event">VIEW EVENT &rarr;</a>
    </div>
  </div>
</article>

<style>
  .event-row {
    display: flex;
    align-items: center;
    gap: 3rem;
  }
  .event-media {
    flex: 0 0 48%;
    max-width: 520px;
    border-radius: 4px;
    overflow: hidden;
  }
  .event-media img {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
  }
  .event-meta {
    flex: 1;
  }
  .event-title {
    margin: 0 0 0.5rem;
    text-transform: uppercase;
    font-weight: 700;
    font-size: clamp(1rem, 2vw, 1.1rem);
    letter-spacing: 0.05em;
    line-height: 1.5;
  }
  .event-date {
    margin: 0;
    color: #c9d3e1;
    font-size: 0.95rem;
    line-height: 1.6;
  }
  .event-cta {
    margin-top: 1.5rem;
  }
  .btn-event {
    display: inline-block;
    padding: 0.8rem 1.5rem;
    background: #f0f0f0;
    color: #1a2740;
    border: 1px solid #dcdcdc;
    border-radius: 3px;
    font-weight: 600;
    text-decoration: none;
    transition: background-color 0.2s, transform 0.2s;
  }
  .btn-event:hover {
    background: #ffffff;
    transform: translateY(-2px);
  }
  @media (max-width: 850px) {
    .event-row {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.5rem;
    }
    .event-media {
      width: 100%;
      flex-basis: auto;
      max-width: none;
    }
  }
</style>
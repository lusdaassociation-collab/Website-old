---
export const prerender = false;
const {
  gap = 32,
  mediaH = 361,
  mediaW = 540,
  navInset = "18px",
} = Astro.props;
---



<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/keen-slider@6.8.6/keen-slider.min.css" />

<div class="ks" data-keen style={`--gap:${gap}px; --media-w:${mediaW}px; --media-h:${mediaH}px; --nav-inset:${navInset};`}>
  <div class="keen-slider" data-keen-track>
    <slot />
  </div>

  <button class="nav prev" aria-label="Previous">
    <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
      <path d="M15 18l-6-6 6-6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
    </svg>
  </button>
  <button class="nav next" aria-label="Next">
    <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
      <path d="M9 6l6 6-6 6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
    </svg>
  </button>
</div>

<script type="module">
  import KeenSlider from "https://cdn.jsdelivr.net/npm/keen-slider@6.8.6/+esm";

  const roots = Array.from(
    document.querySelectorAll('.ks[data-keen]:not([data-keen-inited="1"])')
  );

  for (const root of roots) {
    try {
      const track = root.querySelector("[data-keen-track]");
      if (!track) {
        console.error("[Keen] track element not found in", root);
        continue;
      }

      root.dataset.keenInited = "1";

      Array.from(track.children).forEach((el) =>
        el.classList.add("keen-slider__slide")
      );

      const getGap = () => {
        const v = getComputedStyle(root).getPropertyValue("--gap").trim();
        const n = parseFloat(v || "0");
        return Number.isFinite(n) ? n : 0;
      };

      const slider = new KeenSlider(track, {
        loop: true,
        renderMode: "performance",
        drag: true,
        slides: { perView: 1, spacing: getGap() },
        breakpoints: {
          "(min-width: 540px)":  { slides: { perView: 3, spacing: getGap() } },
          "(min-width: 1100px)": { slides: { perView: 3, spacing: getGap() } },
        },
      });

      root.querySelector(".prev")?.addEventListener("click", () => slider.prev());
      root.querySelector(".next")?.addEventListener("click", () => slider.next());

      const onResize = () => slider.update({ slides: { spacing: getGap() } });
      window.addEventListener("resize", onResize);

      root.__keen = slider;

      const obs = new MutationObserver(() => {
        if (!document.body.contains(root)) {
          window.removeEventListener("resize", onResize);
          obs.disconnect();
          try { slider.destroy(); } catch {}
        }
      });
      obs.observe(document.body, { childList: true, subtree: true });
    } catch (e) {
      console.error("[Keen] init failed:", e);
    }
  }
</script>

<style>

  .ks { position: relative; }
  .keen-slider {
    width: min(1600px, 98%);
    height: 545px;
    margin: 0 auto;
    overflow: hidden;
  }
  .keen-slider { user-select: none; touch-action: pan-y; }
  .keen-slider__slide { position: relative; }

  :global(.ks .keen-slider__slide){
  display: flex;
  justify-content: center;
}

:global(.ks .keen-slider__slide .media){
  width: var(--media-w);
  height: var(--media-h);
  overflow: hidden;
  background: #e9e5df;
  border-radius: 8px;
  flex: 0 0 auto;
}
:global(.ks .keen-slider__slide.card){
  display: flex;
  flex-direction: column;
  align-items: center;
  width: var(--media-w); 
  min-height: calc(var(--media-h) + var(--text-space, 110px));
  padding: 8px 0;
  box-sizing: border-box;
}
:global(.ks .keen-slider__slide .media > img){
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}


:global(.ks .keen-slider__slide > img:first-child),
:global(.ks .keen-slider__slide > picture:first-child),
:global(.ks .keen-slider__slide > a:first-child){
  width: var(--media-w);
  height: var(--media-h);
  overflow: hidden;
  background: #e9e5df;
  border-radius: 8px;
  flex: 0 0 auto;
  display: block;
}
:global(.ks .keen-slider__slide > img:first-child),
:global(.ks .keen-slider__slide > picture:first-child > img),
:global(.ks .keen-slider__slide > a:first-child > img){
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}


  .nav{
    position:absolute; top:45%; transform:translateY(-50%);
    width:46px; height:46px; border-radius:9999px;
    background:rgba(15,53,84,.95); color:#fff;
    border:2px solid rgba(255,255,255,.75);
    display:grid; place-items:center; cursor:pointer;
    transition:transform .12s ease, background .15s ease; z-index:2;
  }
  .nav:hover{ background:#0f3554; transform: translateY(-50%) scale(1.05); }
  .nav:active{ transform: translateY(-50%) scale(.98); }
  .prev{ left:-12px; } .next{ right:-12px; }
  @media (max-width:520px){ .prev{ left:6px; } .next{ right:6px; } }
  :root {
  --media-fallback-h: clamp(180px, 26vw, 260px);
}




.ks .keen-slider__slide .media {
  width: min(var(--media-max-w), 100%);
  aspect-ratio: var(--media-ratio);
  margin-inline: auto;          
  overflow: hidden;
  background: #e9e5df;
  border-radius: 8px;  
}
.ks .keen-slider__slide .media > img {
  width: 100%;
  object-fit: cover;
  display: block;
}
</style>